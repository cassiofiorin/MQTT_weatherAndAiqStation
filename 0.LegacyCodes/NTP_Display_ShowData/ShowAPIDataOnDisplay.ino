    display.display();
    return;
  }
  display.setTextSize(1);
  display.setCursor(35, 1);
  display.println(&timeinfo, "%d/%m/%Y");
  display.display();

  display.setCursor(5, 16);
  display.setTextSize(4);
  display.println(&timeinfo, "%H:%M"/*:%S"*/);
  display.display();
}


